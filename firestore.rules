rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasUserRole(role) {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && get(userPath(request.auth.uid)).data.role == role;
    }

    function isManager() {
      return hasUserRole('manager');
    }

    function isInvestor() {
      return hasUserRole('investor');
    }

    match /users/{userId} {
      allow read: if isManager() || (signedIn() && request.auth.uid == userId);
      allow create, update, delete: if isManager();
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isManager();
    }

    match /orders/{orderId} {
      allow read: if isManager() || isInvestor();
      allow create, update, delete: if isManager();
    }

    match /products/{productId} {
      allow read: if isManager() || isInvestor();
      allow create, update, delete: if isManager();
    }

    match /investors/{investorId} {
      allow read: if isManager() || isInvestor();
      allow create, update, delete: if isManager();
    }

    match /investorExpenses/{expenseId} {
      allow read: if isManager() || isInvestor();
      allow create: if isInvestor()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.purpose is string
        && request.resource.data.purpose.size() > 0;
      allow update: if isManager();
      allow delete: if isManager() || (isInvestor() && resource.data.uid == request.auth.uid && resource.data.status == 'rejected');
    }
  }
}
